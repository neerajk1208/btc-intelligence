{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python run_with_ui.py --min-size 250 --max-size 1000 --entry 2 --exit 5 --slip 10 --quicktrade --cycles 999",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
