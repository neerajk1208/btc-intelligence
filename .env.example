# ETH Arbitrage - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env TO VERSION CONTROL

# =============================================================================
# Definitive Auth (all from DevTools → Network → quote request → Headers)
# =============================================================================

# Privy Access Token (expires ~1 hour, refresh by reloading Definitive)
# Header name: privy-token
PRIVY_ACCESS_TOKEN=eyJhbGciOiJFUzI1NiIs...

# Organization ID (stable, doesn't expire)
# Header name: organization-id
DEFINITIVE_ORG_ID=cdce88c4-d505-4cb3-b54a-...

# Portfolio ID (stable, doesn't expire)
# Header name: portfolio-id
DEFINITIVE_PORTFOLIO_ID=2fac9be7-3c41-4090-...

# Read Token (stable, doesn't expire)
# Header name: read-token
DEFINITIVE_READ_TOKEN=c8725aac-6f23-4454-...

# =============================================================================
# Hyperliquid Trading (for order placement)
# =============================================================================

# Private key for signing orders (hex string, with or without 0x prefix)
# Generate a new wallet for trading - don't use your main wallet!
HL_API_SECRET=0x...

# Set to "true" to enable live order placement (default: false = dry run)
ENABLE_LIVE_TRADING=false

# =============================================================================
# Optional
# =============================================================================

# Telegram Bot (for push notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
